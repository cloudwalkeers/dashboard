# ── Instagram Graph API credentials ────────────────────────────────────────
# Copy this file to ".env" and fill in the two required values.
# Full step-by-step setup is in README.md.

# The Instagram BUSINESS/CREATOR account id (a long number, NOT your @handle).
IG_USER_ID=

# A long-lived access token with these scopes:
#   instagram_basic, instagram_manage_insights, pages_show_list, pages_read_engagement
IG_ACCESS_TOKEN=

# ── Optional ────────────────────────────────────────────────────────────────
# Graph API version to call.
GRAPH_VERSION=v21.0

# Max number of reels to pull per sync (each one downloads its video once to
# read the real duration, so keep this reasonable).
MAX_REELS=40

# Local port for the dashboard.
PORT=5173

# ── AI breakdown pipeline (npm run analyze) ─────────────────────────────────
# OpenAI key for frame descriptions, transcription, and analysis.
OPENAI_API_KEY=
# Optional model overrides (defaults shown). Vision + analysis need a vision-capable
# model; transcription needs an audio model enabled for your project.
OPENAI_VISION_MODEL=gpt-4.1
OPENAI_ANALYSIS_MODEL=gpt-4.1
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ── Supabase (stores each extraction, normalized, for analysis) ─────────────
# Service-role key — server-side only, never expose to the browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
