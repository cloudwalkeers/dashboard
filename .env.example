# ── Instagram Graph API credentials ────────────────────────────────────────
# Copy this file to ".env" and fill in the two required values.
# Full step-by-step setup is in README.md.

# The Instagram BUSINESS/CREATOR account id (a long number, NOT your @handle).
IG_USER_ID=

# A long-lived access token with these scopes:
#   instagram_basic, instagram_manage_insights, pages_show_list, pages_read_engagement
IG_ACCESS_TOKEN=

# ── Optional ────────────────────────────────────────────────────────────────
# Graph API version to call.
GRAPH_VERSION=v21.0

# Max number of reels to pull per sync (each one downloads its video once to
# read the real duration, so keep this reasonable).
MAX_REELS=40

# Local port for the dashboard.
PORT=5173

# ── AI breakdown pipeline (npm run analyze) ─────────────────────────────────
# OpenAI key for frame descriptions, transcription, and analysis.
OPENAI_API_KEY=
# Optional model overrides (defaults shown). Vision + analysis need a vision-capable
# model; transcription needs an audio model enabled for your project.
OPENAI_VISION_MODEL=gpt-4.1
OPENAI_ANALYSIS_MODEL=gpt-4.1
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ── Supabase (stores each extraction, normalized, for analysis) ─────────────
# Service-role key — server-side only, never expose to the browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# ── cloudwalkeers: creator platform connections (per-creator OAuth) ──────────
# Instagram App (Meta): developers.facebook.com → your app → App settings → Basic
# for the ID + Secret. Whitelist the redirect URI under the Instagram-login product's
# OAuth settings (add BOTH your prod URL and this localhost one for testing).
IG_APP_ID=
IG_APP_SECRET=
IG_OAUTH_REDIRECT=http://localhost:5173/api/connect/instagram/callback
# Optional: dedicated secret used to HMAC-sign the OAuth "state" nonce.
# Defaults to SUPABASE_SERVICE_ROLE_KEY when unset.
CW_OAUTH_STATE_SECRET=

# ── Discovery (hashtag search) ────────────────────────────────────────────────
# Preferred: HikerAPI key (hikerapi.com) — pay-per-request vendor lane with reel
# VIEW COUNTS + outlier scores, effectively unlimited. One key serves all clients.
HIKERAPI_KEY=
# Fallback lane (official Meta API — no view counts, 30 unique hashtags/week):
# a Facebook-login Business token + the numeric IG business id.
IG_DISCOVERY_TOKEN=
IG_DISCOVERY_USER_ID=
